[
  {
    "name": "Client JS (route /)",
    "path": ".vercel/output/static/_astro/**/*.js",
    "limit": "20 KB"
  },
  {
    "name": "Fonts (WOFF2)",
    "path": ".vercel/output/static/**/*.woff2",
    "gzip": false,
    "limit": "30 KB"
  },
  {
    "name": "HTML document (/)",
    "path": ".vercel/output/static/index.html",
    "limit": "40 KB"
  },
  {
    "name": "Total home payload (/)",
    "path": [
      ".vercel/output/static/index.html",
      ".vercel/output/static/_astro/**/*.css",
      ".vercel/output/static/_astro/**/*.js",
      ".vercel/output/static/**/*.woff2"
    ],
    "limit": "120 KB"
  }
]
