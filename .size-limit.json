[
  {
    "name": "CSS",
    "path": "dist/_astro/**/*.css",
    "limit": "25 KB"
  },
  {
    "name": "Fonts (WOFF2)",
    "path": "dist/**/*.woff2",
    "gzip": false,
    "limit": "30 KB"
  },
  {
    "name": "HTML document (/)",
    "path": "dist/index.html",
    "limit": "40 KB"
  },
  {
    "name": "Total home payload (/)",
    "path": [
      "dist/index.html",
      "dist/_astro/**/*.css",
      "dist/_astro/**/*.js",
      "dist/**/*.woff2"
    ],
    "limit": "120 KB"
  }
]
