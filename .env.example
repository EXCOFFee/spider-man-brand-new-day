# Upstash Redis credentials for the global counter (server-only, never bundled).
# The site renders fully without these: the counter falls back to the value
# inlined in the HTML at build time.
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# Build-time fallback shown before/without a live counter read.
PUBLIC_SLINGERS_FALLBACK="14238"
