# Hoisted (npm-style) node_modules. The Vercel adapter bundles the serverless
# function by recreating any symlinked dependency as a symlink; with pnpm's
# default isolated store that fails on filesystems without symlink permission
# (e.g. Windows without Developer Mode). A hoisted layout has real directories,
# so the adapter copies instead, and the build works on every platform.
node-linker=hoisted
